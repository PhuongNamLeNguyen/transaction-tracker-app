# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/transaction_tracker

# ─── App ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
PORT=3000
NODE_ENV=development
BCRYPT_ROUNDS=10

# URLs — update to real domains in production
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ─── Anthropic API ────────────────────────────────────────────
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google OAuth ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Leave empty to disable Google Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# ─── Email (Gmail SMTP) ───────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Create an app password and paste it as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
FROM_EMAIL=your-email@gmail.com
